{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalPassThroughEnv": [
    "NEXT_PUBLIC_SERVER_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", ".open-next/**"]
    },
    "lint": { "dependsOn": ["^lint"] },
    "check-types": { "dependsOn": ["^check-types", "^build"] },
    "test": { "dependsOn": [], "outputs": [] },
    "dev": { "cache": false, "persistent": true },
    "db:generate": { "cache": false },
    "db:push": { "cache": false },
    "es:generate": { "cache": false },
    "deploy": {
      "cache": false,
      "dependsOn": ["@yoyaku/server#build"],
      "passThroughEnv": [
        "ALCHEMY_DEPLOY",
        "ALCHEMY_STAGE",
        "ALCHEMY_PASSWORD",
        "ALCHEMY_STATE_TOKEN",
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "CORS_ORIGIN",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SNAPSHOT_SECRET",
        "STRIPE_WEBHOOK_THIN_SECRET",
        "STRIPE_CONNECT_COUNTRY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "TURNSTILE_SECRET_KEY",
        "ADMIN_API_TOKEN"
      ]
    },
    "destroy": {
      "cache": false,
      "passThroughEnv": [
        "ALCHEMY_DEPLOY",
        "ALCHEMY_STAGE",
        "ALCHEMY_PASSWORD",
        "ALCHEMY_STATE_TOKEN",
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID"
      ]
    }
  }
}
