# yoyaku ローカル開発用の環境変数。
# 本番デプロイは GitHub Actions 経由のため、Cloudflare 認証情報や本番シークレットはここに置かない。

# --- Alchemy（ローカル state のシークレット暗号化に必須）---
ALCHEMY_PASSWORD=lB227l6+Kk3NGqGNGmq5Ckev65ku2M8qQof+cOFu/pI=

# --- URL / CORS（ポートは alchemy.run.ts の dev 設定: server=3000 / web=3001）---
BETTER_AUTH_URL=https://3000.mydevbox.pp.ua
NEXT_PUBLIC_SERVER_URL=https://3000.mydevbox.pp.ua
CORS_ORIGIN=https://3001.mydevbox.pp.ua

# --- Better Auth（`openssl rand -base64 32` で生成）---
BETTER_AUTH_SECRET=LFuZOULV/q/8OMGnuDyGjWJ6CA+cjwEyzrCGZrywbE4=

# --- Google Sign-in（redirect URI: https://3000.mydevbox.pp.ua/api/auth/callback/google）---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe（テストキー: https://dashboard.stripe.com/test/apikeys）---
STRIPE_SECRET_KEY=sk_test_
# Snapshot destination: https://3000.mydevbox.pp.ua/api/stripe/webhook/snapshot
STRIPE_WEBHOOK_SNAPSHOT_SECRET=whsec_
# Thin destination: https://3000.mydevbox.pp.ua/api/stripe/webhook/thin
STRIPE_WEBHOOK_THIN_SECRET=whsec_
# Accounts v2 connected account 作成時の国。JPY/日本運用の既定は JP。
STRIPE_CONNECT_COUNTRY=JP
# Web の決済 UI（Phase 08）で必須の公開鍵:
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# --- Cloudflare Turnstile（Phase 09・FR-17。高リスク公演で必須）---
# dev はテスト用キーで常に成功（本番は dashboard で発行）。
#   site key（公開・常に成功）: 1x00000000000000000000AA
#   secret（常に成功）:          1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- 運用/管理（Phase 10・NFR-17）---
# 再投影・as-of・照合手動実行・メトリクスの管理エンドポイントを X-Admin-Token で認可。
# 任意の十分長いランダム文字列（例: `openssl rand -hex 32`）。本番は GitHub Actions 経由で注入。
ADMIN_API_TOKEN=dev-admin-token-change-me
